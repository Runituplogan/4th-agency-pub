// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres", "driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String     @id @default(uuid())
  firstName    String
  secondName   String
  username     String?    @unique
  email        String     @unique
  phoneNumber  String?    @unique
  password     String?
  status       UserStatus @default(ACTIVE)
  verified     Boolean    @default(false)
  googleId     String?
  profileImage String?

  passwordChangedAt           DateTime?
  passwordResetCode           String?     @unique
  passwordResetLastSent       DateTime?
  passwordResetAttempts       Int         @default(0)
  passwordResetAttemptResetAt DateTime?
  passwordResetExpires        DateTime?
  emailVerificationToken      String?     @unique
  emailTokenExpires           DateTime?
  signUpMode                  SignupMode?
  refreshToken                String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  carts    Cart[]
  orders   Order[]
  payments Payment[]

  deActivatedAt DateTime?
  activatedAt   DateTime?

  @@index([email])
  @@index([status])
  @@index([username])
  @@index([phoneNumber])
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
  DEACTIVATED
}

enum SignupMode {
  OAUTH
  REGULAR
}

model Cart {
  id     String     @id @default(uuid())
  userId String     @unique
  status CartStatus @default(ACTIVE)
  user   User       @relation(fields: [userId], references: [id])
  items  CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]

  @@index([status])
}

model CartItem {
  id     String @id @default(uuid())
  cartId String
  cart   Cart   @relation(fields: [cartId], references: [id], onDelete: Cascade)

  placementId String?

  name       String?
  websiteUrl String?
  logoUrl    String?
  country    String?
  outletName String?

  channelType     String?
  placementType   String?
  domainAuthority Int?
  domainRanking   Int?
  isDoFollow      Boolean @default(false)

  minDeliveryDays Int?
  maxDeliveryDays Int?

  unitAmount  Float?
  pricingTier String?
  currency    String  @default("usd")
  quantity    Int     @default(1)

  contentType    String?
  contentTypeFee Float   @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cartId])
  @@index([placementId])
}

enum CartStatus {
  ACTIVE
  CHECKED_OUT
  ABANDONED
}

model Order {
  id     String      @id @default(uuid())
  userId String
  cartId String
  user   User        @relation(fields: [userId], references: [id])
  cart   Cart        @relation(fields: [cartId], references: [id])
  status OrderStatus @default(PENDING)

  stripePaymentIntentId String  @unique
  stripeChargeId        String?

  subtotal      Float
  processingFee Float
  amountTotal   Float
  currency      String @default("USD")

  items OrderItem[]

  paidAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  payments Payment[]

  @@index([userId])
  @@index([status])
  @@index([stripePaymentIntentId])
}

model OrderItem {
  id      String @id @default(uuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  placementId     String?
  name            String?
  websiteUrl      String?
  logoUrl         String?
  country         String?
  outletName      String?
  channelType     String?
  placementType   String?
  domainAuthority Int?
  domainRanking   Int?
  isDoFollow      Boolean @default(false)
  minDeliveryDays Int?
  maxDeliveryDays Int?
  unitAmount      Float?
  pricingTier     String?
  currency        String  @default("usd")
  quantity        Int

  contentType    String?
  contentTypeFee Float   @default(0)

  createdAt DateTime @default(now())

  @@index([orderId])
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model Payment {
  id      String  @id @default(uuid())
  orderId String?
  order   Order?  @relation(fields: [orderId], references: [id])
  userId  String
  user    User    @relation(fields: [userId], references: [id])

  stripePaymentIntentId String? @unique
  stripeChargeId        String?
  stripeCustomerId      String?
  stripeClientSecret    String?
  stripeSessionId       String?

  amount        Float
  currency      String        @default("USD")
  status        PaymentStatus
  paymentMethod String?
  last4         String?
  cardBrand     String?

  stripeEvent Json?

  failureCode    String?
  failureMessage String?

  paidAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  expiresAt DateTime?

  @@index([orderId])
  @@index([userId])
  @@index([stripePaymentIntentId])
  @@index([status])
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
  DISPUTED
}
